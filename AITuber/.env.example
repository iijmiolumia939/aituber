# AITuber Orchestrator - 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください。
# cp .env.example .env

# ── YouTube Data API ──────────────────────────────────────────────
YOUTUBE_API_KEY=
# YOUTUBE_LIVE_CHAT_ID は省略可。未設定の場合、起動時に自動取得 (FR-CHATID-AUTO-01)。
# OAuth (config/youtube_token.json) が優先。なければ YOUTUBE_CHANNEL_ID + YOUTUBE_API_KEY で取得。
YOUTUBE_LIVE_CHAT_ID=
# YOUTUBE_CHANNEL_ID=   # API キーによる自動取得フォールバック用 (例: UCxxxxxxxx)

# ── キャラクター設定 ──────────────────────────────────────────────────────
# CHARACTER_NAME で config/characters/<name>.yml を読み込む
# CHARACTER_NAME=yuia   # デフォルト推奨

# ── OpenAI / LLM API ─────────────────────────────────────────────
OPENAI_API_KEY=
# LLM バックエンド切替 (FR-LLM-BACKEND-01)
# デフォルトは OpenAI。LLM_BASE_URL/LLM_MODEL/LLM_API_KEY で切替可能。
# LLM_API_KEY=          # 省略時は OPENAI_API_KEY を使用
# LLM_BASE_URL=         # 省略時は OpenAI エンドポイント
# LLM_MODEL=gpt-4o-mini # デフォルトモデル
#
# --- Google Gemini (推奨: gemini-2.5-flash) ---
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=AIzaxxxx  # Google AI Studio で取得
#
# --- Groq (超低レイテンシ・無料枠あり) ---
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_xxxx
#
# --- DeepSeek (最安値級) ---
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxxx
#
# --- OpenRouter (複数モデルを一本化) ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemini-2.5-flash-preview
# LLM_API_KEY=sk-or-xxxx
# ── TTS エンジン ─────────────────────────────────────────────────
# "voicevox" (デフォルト) or "style_bert_vits2"
TTS_BACKEND=voicevox
TTS_PORT=50021
TTS_SPEAKER_ID=1
# sounddevice 出力先 (デバイス名または index)。未設定でOS既定。
# AUDIO_OUTPUT_DEVICE=VB-Audio Virtual Cable

# Style-BERT-VITS2 を使う場合（TTS_BACKEND=style_bert_vits2）
# SBV2_MODEL_ID=0
# SBV2_STYLE=Neutral
# TTS_PORT=5000

# ── キャラクター設定 ─────────────────────────────────────────────
# デフォルト: config/character.yml
# CHARACTER_CONFIG_PATH=config/character.yml

# ── Game stream automation (FR-LAYOUT-03 / FR-LAYOUT-04) ──────────
# GameLoop 起動時にゲームを自動起動する場合に有効化
# GAME_AUTO_LAUNCH=1
# Windows 例: start "" "C:\\Path\\To\\MinecraftLauncher.exe"
# GAME_LAUNCH_COMMAND=

# OBS GameCapture 入力の自動割当 (Game_Main 遷移時)
# source 名は tools/setup_obs.py のデフォルトで "GameCapture"
# GAME_CAPTURE_SOURCE_NAME=GameCapture
# 例: Minecraft*:GLFW30:javaw.exe
# GAME_CAPTURE_WINDOW=

# クラッシュ/切断フォロー設定
# 切断時に自動再起動する
# GAME_RELAUNCH_ON_DISCONNECT=1
# 再起動試行クールダウン秒
# GAME_RELAUNCH_COOLDOWN_SEC=20
# 切断と判定して退避レイアウトへ切り替えるまでの猶予秒
# GAME_DISCONNECT_GRACE_SEC=5
# 切断時の退避先シーン (opening|chat|ending)
# GAME_DISCONNECT_HIDE_SCENE=opening

# ── Overlay WS ───────────────────────────────────────────────────────
# OBS Browser Source が接続する Overlay WebSocket ポート
# OVERLAY_WS_PORT=31902

# ── OBS setup_obs.py オプション ─────────────────────────────────────
# Avatar の window selector（環境に合わせて変更）
# OBS_AVATAR_WINDOW=AITuber:UnityWndClass:AITuber.exe
# Unity Editor を直接キャプチャする例
# OBS_AVATAR_WINDOW=UnityEditor:UnityWndClass:Unity.exe

# OBS 既定音声デバイスの有効/無効
# OBS_INCLUDE_DESKTOP_AUDIO=1
# OBS_INCLUDE_MIC_AUDIO=1

# Game_Main にゲーム音声ソースを追加
# OBS_INCLUDE_GAME_AUDIO=1
# OBS_GAME_AUDIO_DEVICE_ID=default

# 配信用BGMソースを追加
# OBS_INCLUDE_STREAM_BGM=1
# OBS_STREAM_BGM_FILE=C:\\media\\bgm\\stream_loop.mp3
# OBS_STREAM_BGM_LOOP=1
